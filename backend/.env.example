# =============================================================================
# SOPHIA COMMONS - Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to git. Add it to .gitignore.
#
# Get your Supabase values from:
#   https://app.supabase.com -> Your Project -> Settings -> API
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE - Required
# -----------------------------------------------------------------------------

# Your Supabase project URL (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=your-project-url

# Supabase anon / public key (safe to expose in the browser)
# Used for all client-side queries. RLS policies protect your data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (SECRET - server-side only)
# Has full database access and bypasses RLS. Never expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# -----------------------------------------------------------------------------
# SITE
# -----------------------------------------------------------------------------

# The canonical URL of your site.
# Development:  http://localhost:3000
# Production:   https://sophiacommons.org
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# OPTIONAL: Email (for transactional email via Resend, Postmark, etc.)
# Supabase handles auth emails natively, but custom transactional email
# (newsletter confirmations, listing alerts) can use any SMTP provider.
# -----------------------------------------------------------------------------

# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=noreply@sophiacommons.org


# -----------------------------------------------------------------------------
# OPTIONAL: Analytics
# -----------------------------------------------------------------------------

# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com


# -----------------------------------------------------------------------------
# OPTIONAL: Upstash Redis (for rate limiting via @upstash/ratelimit)
# -----------------------------------------------------------------------------

# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
