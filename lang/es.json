  "catmeta.biodynamic_name": "Agricultura Biodinamica",
  "catmeta.biodynamic_desc": "Granjas biodinamicas certificadas por Demeter, programas de CSA, aprendizajes, proveedores de semillas, cursos de formacion e investigacion agricola en la tradicion de Rudolf Steiner.",
  "catmeta.esoteric_name": "Estudios Esotericos",
