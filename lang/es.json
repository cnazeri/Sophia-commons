  "catmeta.medicine_name": "Medicina Antroposofica",
  "catmeta.medicine_desc": "Medicos antroposoficos, clinicas, hospitales, euritmia terapeutica, terapia artistica, remedios Weleda y WALA, y programas de formacion de enfermeria.",
  "catmeta.camphill_name": "Comunidad y Camphill",
